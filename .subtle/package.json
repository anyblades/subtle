{
  "private": true,
  "name": "subtle.blades.ninja",
  "type": "module",
  "scripts": {
    "start": "npm run build -- --serve",
    "stage": "rm -r ./_site/ || true && npm run build && serve ./_site/",
    "build": "eleventy --input=../",
